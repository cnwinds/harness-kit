# 复制为 .env 后填写（.env 不会被 git 跟踪）
# cp .env.example .env

# DashScope 示例
OPENAI_API_KEY=sk-your-dashscope-api-key
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen3.5-plus

# Native 能力（官方 api.openai.com 时 auto=开启；中转站默认 off）
OPENAI_NATIVE_WEB_SEARCH=auto
OPENAI_NATIVE_IMAGE_GENERATION=auto

# 服务
PORT=3000
HARNESSKIT_DATA_ROOT=./data
HARNESSKIT_INLINE_JOBS=true

# 联网搜索：live | cached | disabled
WEB_SEARCH_MODE=live
# WEB_SEARCH_PROVIDERS=openai_native,tavily,serper,brave
# TAVILY_API_KEY=
# SERPER_API_KEY=
# BRAVE_SEARCH_API_KEY=

# 三方生图（有 key + model 即激活）
# OPENAI_IMAGE_API_KEY=
# OPENAI_IMAGE_BASE_URL=https://api.openai.com/v1
# OPENAI_IMAGE_MODEL=gpt-image-2
# ZHIPU_IMAGE_API_KEY=
# ZHIPU_IMAGE_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# ZHIPU_IMAGE_MODEL=glm-image
# DASHSCOPE_IMAGE_API_KEY=
# DASHSCOPE_IMAGE_BASE_URL=https://dashscope.aliyuncs.com
