{
  "name": "@harnesskit/core",
  "version": "0.1.1",
  "description": "HarnessKit turn runtime, stream hub, storage, and runner",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
