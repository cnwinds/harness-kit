{
  "name": "@harnesskit/harness",
  "version": "0.1.1",
  "description": "HarnessKit LLM harness engine — OpenAI Responses agent loop",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
