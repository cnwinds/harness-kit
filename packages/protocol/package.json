{
  "name": "@harnesskit/protocol",
  "version": "0.1.0",
  "description": "HarnessKit cross-platform types, Zod schemas, and SSE event contract",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "vitest": "^4.0.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
