    "fastify": "^5.0.0",
    "nanoid": "^5.1.6",
    "zod": "^4.1.12"
  },
  "peerDependencies": {
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "vitest": "^4.0.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
