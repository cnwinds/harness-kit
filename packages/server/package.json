{
  "name": "@harnesskit/server",
  "version": "0.1.0",
  "description": "HarnessKit Fastify adapter — createHarnessChat() one-line mount",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@harnesskit/protocol": "0.1.0",
    "@harnesskit/core": "0.1.0",
    "@harnesskit/harness": "0.1.0",
